# minote-skill 运行时配置模板
# 复制本文件为 .env，然后把示例路径替换成你自己的本地路径。

# 内置运行层的根目录。
# 默认建议使用相对路径 `.\script`。
# 只有在 debug 模式或临时切换到外部 minote-driver 仓库时，才改成具体绝对路径。
MINOTE_RUNTIME_ROOT=.\script

# 本地 Chrome 可执行文件的完整路径。
MINOTE_CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe

# chromedriver.exe 路径。
# 默认建议使用相对路径，指向当前仓库里的 script\bin\chromedriver.exe。
MINOTE_CHROMEDRIVER_EXE=.\script\bin\chromedriver.exe

# 当前项目使用的 Chrome 用户数据目录。
# 这个目录会保存本地的小米登录态。
# 默认建议使用相对路径，指向当前仓库里的 script\chrome_profile。
MINOTE_CHROME_USER_DATA_DIR=.\script\chrome_profile

# Chrome 远程调试端口。
# 这个端口用于启动带 remote debugging 的 Chrome，通常保持默认即可。
MINOTE_REMOTE_DEBUGGING_PORT=9222
