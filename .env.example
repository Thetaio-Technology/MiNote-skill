# minote-skill runtime configuration
# Copy this file to .env and replace the example paths with your own local paths.

# Root directory of the embedded runtime.
MINOTE_RUNTIME_ROOT=E:\Code\TEMScript\Minote-skill\script

# Full path to your local Chrome executable.
MINOTE_CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe

# Full path to chromedriver.exe.
# Put the driver under script\bin\chromedriver.exe unless you have a custom location.
MINOTE_CHROMEDRIVER_EXE=E:\Code\TEMScript\Minote-skill\script\bin\chromedriver.exe

# Chrome user data directory used by this project.
# This directory stores the local Xiaomi login session.
MINOTE_CHROME_USER_DATA_DIR=E:\Code\TEMScript\Minote-skill\script\chrome_profile

# Target page and remote debugging port.
MINOTE_TARGET_URL=https://i.mi.com/note/#/
MINOTE_REMOTE_DEBUGGING_PORT=9222
